# API publica consumida pelo app Expo em producao.
EXPO_PUBLIC_API_URL=https://api.dular.com.br

# Alias de compatibilidade — mesmo valor de EXPO_PUBLIC_API_URL (codigo legado le este nome).
EXPO_PUBLIC_API_BASE_URL=https://api.dular.com.br

# Desativa defaults de piloto em producao.
EXPO_PUBLIC_PILOT_MODE=false

# Preencher apenas se a operacao de producao ainda precisar travar uma cidade inicial.
EXPO_PUBLIC_PILOT_CITY=

# Latitude de referencia da cidade piloto, se EXPO_PUBLIC_PILOT_CITY for usada.
EXPO_PUBLIC_PILOT_LAT=

# Longitude de referencia da cidade piloto, se EXPO_PUBLIC_PILOT_CITY for usada.
EXPO_PUBLIC_PILOT_LNG=

# UF da cidade piloto (padrao no codigo: MT).
EXPO_PUBLIC_PILOT_UF=

# Bairros atendidos, separados por virgula. Devem existir no banco (seed:prod do web).
EXPO_PUBLIC_PILOT_BAIRROS=

# WhatsApp do SOS sem "+", ex: 5566999999999.
EXPO_PUBLIC_SOS_WHATSAPP=
