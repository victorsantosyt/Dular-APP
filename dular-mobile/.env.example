EXPO_PUBLIC_API_URL=https://api.seudominio.com
# Compat temporária com builds/devs antigos. Prefira EXPO_PUBLIC_API_URL.
EXPO_PUBLIC_API_BASE_URL=https://api.seudominio.com
EXPO_PUBLIC_PILOT_MODE=false
EXPO_PUBLIC_PILOT_CITY=Cuiabá
EXPO_PUBLIC_PILOT_UF=MT
EXPO_PUBLIC_PILOT_LAT=-15.601
EXPO_PUBLIC_PILOT_LNG=-56.097
EXPO_PUBLIC_PILOT_BAIRROS=Centro,Santa Rosa,Jardim Itália
# Número WhatsApp SOS (sem o +, ex: 5565999999999). Lido via Constants.expoConfig.extra.sosWhatsapp
# Configurado em app.json > extra.sosWhatsapp (não usa prefixo EXPO_PUBLIC_)
EXPO_PUBLIC_SOS_WHATSAPP=5565999999999
# Unidade monetária exibida na interface (ex: R$)
EXPO_PUBLIC_MONEY_UNIT=R$
# URL pública do logo da marca (opcional, fallback para asset local)
EXPO_PUBLIC_LOGO_URL=
