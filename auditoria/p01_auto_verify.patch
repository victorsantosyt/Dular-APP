+/** KYC_AUTO_VERIFY=true liga o caminho seguro de produção. */
+export function isSafeKycAutoVerifyEnabled(): boolean {
+  return process.env.KYC_AUTO_VERIFY === "true";
+}
+
+/**
+ * Verifica se o SafeScore do usuário permite promoção automática.
+ * Score < 400 ou restrição ativa de SHADOW_BAN/SUSPEND/BLOCK bloqueia.
+ */
+async function isSafeScoreOkParaAutoVerify(userId: string): Promise<boolean> {
+  // Dual-read: SafeScoreProfile (novo) → fallback SafeScore legado.
+  const [profile, legacy, restricoes] = await Promise.all([
+    prisma.safeScoreProfile.findUnique({
+      where: { userId },
+      select: { currentScore: true },
+    }),
+    prisma.safeScore.findUnique({
+      where: { userId },
+      select: { score: true },
+    }),
+    prisma.userRestriction.findMany({
+      where: {
+        userId,
+        type: { in: ["SHADOW_BAN", "SUSPEND", "BLOCK"] },
+        revokedAt: null,
+        OR: [{ expiresAt: null }, { expiresAt: { gt: new Date() } }],
+      },
+      select: { type: true },
+    }),
+  ]);
+
+  if (restricoes.length > 0) return false;
+
+  const score = profile?.currentScore ?? legacy?.score ?? 500;
+  return score >= SCORE_MINIMO_AUTO_VERIFY;
+}
+
+/**
+ * Grava nota de auditoria na última DocumentVerification do usuário para o
+ * docType informado. Usa campo reviewNote existente — sem coluna nova.
+ * Silencioso em caso de falha: auditoria não derruba promoção.
+ */
+async function gravarAuditoriaAutoVerify(
+  userId: string,
+  docType: string,
+  timestamp: string,
+): Promise<void> {
+  const nota = `AUTO-VERIFICADO (KYC_AUTO_VERIFY): perfil completo + docs + score OK em ${timestamp}`;
+  try {
+    await prisma.documentVerification.updateMany({
+      where: { userId, docType },
+      data: { reviewNote: nota },
+    });
+  } catch (err) {
+    if (isDev) {
+      const msg = err instanceof Error ? err.message : "unknown";
+      console.log(`[autoVerificacao] falha ao gravar auditoria userId=${userId}: ${msg}`);
+    }
+  }
+}
