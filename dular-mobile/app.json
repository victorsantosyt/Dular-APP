{
  "expo": {
    "name": "dular-mobile",
    "slug": "dular-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "dular",
    "splash": {
      "backgroundColor": "#5B25D9"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dular.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Usamos sua localização para sugerir diaristas e serviços próximos.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Usamos sua localização para sugerir diaristas e serviços próximos."
      }
    },
    "android": {
      "package": "com.dular.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-web-browser",
      "expo-font",
      "expo-secure-store",
      ["expo-location", {
        "locationAlwaysAndWhenInUsePermission": "O Dular usa sua localização durante o serviço para segurança."
      }]
    ],
    "extra": {
      "apiBaseUrl": "SUBSTITUIR_EM_PRODUCAO",
      "sosWhatsapp": "SUBSTITUIR_EM_PRODUCAO"
    }
  }
}
