# Banco
# DATABASE_URL (obrigatoria): URL de conexao do Postgres de producao.
# Onde encontrar: painel do provedor do banco (Railway, Supabase, RDS etc.).
# Formato: postgresql://user:pass@host:5432/dular
DATABASE_URL=postgresql://user:pass@host:5432/dular

# Auth
# JWT_SECRET (obrigatoria): segredo usado para assinar/validar JWTs da API.
# Como gerar: openssl rand -base64 32
# Requisito: minimo 32 caracteres, nunca reutilizar segredo de dev.
JWT_SECRET=

# NEXTAUTH_SECRET (obrigatoria): segredo interno do NextAuth/Auth.js.
# Como gerar: openssl rand -base64 32
# Requisito: minimo 32 caracteres.
NEXTAUTH_SECRET=

# NEXTAUTH_URL (obrigatoria): URL publica do app web em producao.
# Onde definir: dominio final com HTTPS, por exemplo https://app.dular.com.br.
NEXTAUTH_URL=https://app.dular.com.br

# GOOGLE_CLIENT_ID (obrigatoria para login Google): Client ID OAuth do Google.
# Onde encontrar: Google Cloud Console > APIs & Services > Credentials.
GOOGLE_CLIENT_ID=

# GOOGLE_CLIENT_SECRET (obrigatoria para login Google): secret OAuth do mesmo client.
# Onde encontrar: Google Cloud Console > APIs & Services > Credentials.
GOOGLE_CLIENT_SECRET=

# APPLE_ID (obrigatoria para login Apple): Service ID / Client ID configurado na Apple Developer.
# Onde encontrar: Apple Developer > Certificates, Identifiers & Profiles > Identifiers.
APPLE_ID=

# APPLE_SECRET (obrigatoria para login Apple): client secret JWT assinado para Sign in with Apple.
# Como gerar: usando Team ID, Key ID, private key .p8 e Service ID da Apple Developer.
APPLE_SECRET=

# AWS S3
# AWS_ACCESS_KEY_ID (obrigatoria para upload em S3): access key de um usuario IAM com permissao no bucket.
# Onde encontrar: AWS IAM > Security credentials.
AWS_ACCESS_KEY_ID=

# AWS_SECRET_ACCESS_KEY (obrigatoria para upload em S3): secret key correspondente ao AWS_ACCESS_KEY_ID.
# Onde encontrar: exibida apenas na criacao da access key; gere outra se perdeu.
AWS_SECRET_ACCESS_KEY=

# AWS_REGION (obrigatoria para upload em S3): regiao do bucket.
# Onde encontrar: pagina do bucket no S3, exemplo us-east-1 ou sa-east-1.
AWS_REGION=

# AWS_BUCKET_NAME (obrigatoria para upload em S3): nome do bucket que recebera avatares/documentos/anexos.
# Onde encontrar: AWS S3 > Buckets.
AWS_BUCKET_NAME=

# Stripe
# STRIPE_SECRET_KEY (obrigatoria para checkout/billing): chave secreta da conta Stripe.
# Onde encontrar: Stripe Dashboard > Developers > API keys.
STRIPE_SECRET_KEY=

# STRIPE_WEBHOOK_SECRET (obrigatoria para webhooks): segredo do endpoint webhook de producao.
# Onde encontrar: Stripe Dashboard > Developers > Webhooks > endpoint > Signing secret.
STRIPE_WEBHOOK_SECRET=

# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY (obrigatoria para UI de pagamento): chave publicavel da conta Stripe.
# Onde encontrar: Stripe Dashboard > Developers > API keys.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Push Notifications
# EXPO_ACCESS_TOKEN (obrigatoria para envio server-side de push Expo): token de acesso da conta Expo.
# Como gerar: npx expo login; npx expo whoami; criar token em https://expo.dev/accounts/[conta]/settings/access-tokens.
EXPO_ACCESS_TOKEN=

# App
# NEXT_PUBLIC_APP_URL (obrigatoria): URL publica base usada por links e callbacks do app.
# Onde definir: mesmo dominio publico da web/API em producao, por exemplo https://app.dular.com.br.
NEXT_PUBLIC_APP_URL=https://app.dular.com.br

# Seed de producao (npm run seed:prod) — cria admin inicial + bairros da cidade piloto.
# PROD_ADMIN_EMAIL (obrigatoria para o seed): email do admin inicial.
PROD_ADMIN_EMAIL=
# PROD_ADMIN_PASSWORD (obrigatoria para o seed): senha forte, minimo 8 caracteres (recomendado 16+).
# Como gerar: openssl rand -base64 16
PROD_ADMIN_PASSWORD=
# PROD_ADMIN_NOME (opcional): nome exibido do admin. Padrao: Admin Dular.
PROD_ADMIN_NOME=
# PROD_ADMIN_TELEFONE (opcional): telefone do admin (unico no banco).
PROD_ADMIN_TELEFONE=
# Cidade piloto do Beta 0 — bairros criados pelo seed ficam pesquisaveis na busca.
# Exemplo: PILOT_CITY=Agua Boa / PILOT_UF=MT / PILOT_BAIRROS=Centro,Bairro A,Bairro B
PILOT_CITY=
PILOT_UF=
PILOT_BAIRROS=
